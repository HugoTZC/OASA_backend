# ==========================================
# OASA Backend - Development Environment Template
# ==========================================
# Copy this to .env for local development

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database Configuration (Local PostgreSQL)
# Supports MySQL and PostgreSQL - auto-detected from DATABASE_URL prefix
# Or set DB_TYPE manually: mysql | postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=OASA
DB_USER=your_local_db_user
DB_PASSWORD=your_local_db_password
DATABASE_URL=postgresql://user:password@localhost:5432/OASA
# For MySQL:
# DATABASE_URL=mysql://user:password@localhost:3306/OASA
# DB_TYPE=mysql

# JWT Configuration
JWT_SECRET=your-development-jwt-secret
JWT_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=10

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Subscription & Feature Flags
DEFAULT_SUBSCRIPTION_PLAN=basic
